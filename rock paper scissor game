import random

choices=["rock","paper","scissor"]

name=input("Enter your name: ")
print(f"Welcome {name} to Rock Paper Scissor Game")

while True:
    computer=random.choice(choices)

    user=input("Select from Rock-Paper-Sciccor: ").lower()

    if user not in choices:
        print("Please enter a correct choise")
        continue

    if user == computer:
        print("Its a Tie, Try again")

    elif (
        (user == "rock" and computer =="scissor") or 
        (user == "paper" and computer == "rock") or
        (user == "scissor" and computer == "paper") ):
        print(f"{name} Won!!")
    else:
        print("Computer Won!!")

    again=input("You want to play again (yes/no): ").lower()

    if again != "yes":
        print("ThankYou For Playing")
        break
