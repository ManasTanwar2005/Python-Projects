import string

password=input("Enter your passowrd: ")

has_upper = False
has_lower = False
has_digit = False
has_special = False

special_character=string.punctuation

for char in password:
    if char.isupper():
        has_upper = True
    elif char.islower():
        has_lower = True
    elif char.isdigit():
        has_digit = True
    elif char in special_character:
        has_special = True

if (len(password) >= 8 and has_upper and has_lower and has_special and has_digit):
    print("Strong Password")
elif (len(password)<=8):
    print("Weak Password")
else:
    print("Weak Password")
